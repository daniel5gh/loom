---
import { getCollection } from 'astro:content';

interface Props { title: string; }
const { title } = Astro.props;

const aiTools = await getCollection('aiTools');
const cloudPlatforms = await getCollection('cloudPlatforms');
const companies = await getCollection('companies');

const shellData = JSON.stringify([
  ...aiTools.map(doc => {
    const summaryMatch = (doc.body || '').match(/## Summary\n\n([\s\S]*?)(\n##|$)/);
    return {
      slug: doc.id,
      category: 'ai-tools-and-services',
      title: doc.data.title,
      tags: doc.data.tags,
      summary: summaryMatch ? summaryMatch[1].trim().slice(0, 200) : '',
    };
  }),
  ...cloudPlatforms.map(doc => {
    const summaryMatch = (doc.body || '').match(/## Summary\n\n([\s\S]*?)(\n##|$)/);
    return {
      slug: doc.id,
      category: 'cloud-ai-platforms',
      title: doc.data.title,
      tags: doc.data.tags,
      summary: summaryMatch ? summaryMatch[1].trim().slice(0, 200) : '',
    };
  }),
  ...companies.map(doc => {
    const summaryMatch = (doc.body || '').match(/## Summary\n\n([\s\S]*?)(\n##|$)/);
    return {
      slug: doc.id,
      category: 'companies',
      title: doc.data.title,
      tags: doc.data.tags,
      summary: summaryMatch ? summaryMatch[1].trim().slice(0, 200) : '',
    };
  }),
]);
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Loom</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <nav class="site-nav">
      <a href="/" class="nav-home">Loom</a>
      <a href="/tags/" class="nav-tags">Tags</a>
      <a href="/graph/" class="nav-graph">Graph</a>
      <a href="/map/" class="nav-map">Map</a>
    </nav>
    <main>
      <slot />
    </main>

    <script type="application/json" id="shell-data" set:html={shellData}></script>

    <div id="vim-status-bar" class="vim-status-bar" aria-live="polite" aria-atomic="true">
      <span id="vim-mode-label">NORMAL</span>
      <span id="vim-context-label"></span>
    </div>

    <div id="shell-overlay" class="shell-overlay" aria-modal="true" role="dialog" aria-label="Search" hidden>
      <div class="shell-inner">
        <div class="shell-prompt">
          <span class="shell-prompt-label">loom&gt;</span>
          <input id="shell-input" class="shell-input" type="text" autocomplete="off" spellcheck="false" placeholder="" />
          <span class="shell-cursor" aria-hidden="true">_</span>
        </div>
        <ul id="shell-results" class="shell-results" role="listbox" aria-label="Search results"></ul>
      </div>
    </div>

    <script>
      import Fuse from 'fuse.js';

      const rawData = document.getElementById('shell-data')?.textContent ?? '[]';
      const searchData = JSON.parse(rawData);

      const fuse = new Fuse(searchData, {
        keys: [
          { name: 'title',   weight: 0.6 },
          { name: 'tags',    weight: 0.3 },
          { name: 'summary', weight: 0.1 },
        ],
        threshold: 0.35,
        includeScore: false,
      });

      const overlay = document.getElementById('shell-overlay');
      const input = document.getElementById('shell-input');
      const resultsList = document.getElementById('shell-results');

      let overlayOpen = false;
      let selectedIndex = -1;
      let previousFocus = null;

      function isTypingContext() {
        const el = document.activeElement;
        return el && (
          el.tagName === 'INPUT' ||
          el.tagName === 'TEXTAREA' ||
          el.tagName === 'SELECT' ||
          el.isContentEditable
        );
      }

      function openOverlay() {
        overlayOpen = true;
        previousFocus = document.activeElement;
        overlay.removeAttribute('hidden');
        input.value = '';
        renderResults([]);
        input.focus();
      }

      function closeOverlay() {
        overlayOpen = false;
        overlay.setAttribute('hidden', '');
        if (previousFocus && typeof previousFocus.focus === 'function') {
          previousFocus.focus();
        }
      }

      function renderResults(results) {
        resultsList.innerHTML = '';
        selectedIndex = results.length > 0 ? 0 : -1;

        if (results.length === 0 && input.value.trim() !== '') {
          const li = document.createElement('li');
          li.className = 'shell-no-results';
          li.textContent = 'no results';
          resultsList.appendChild(li);
          return;
        }

        results.forEach((r, i) => {
          const doc = r.item;
          const li = document.createElement('li');
          li.className = 'shell-result-item' + (i === 0 ? ' selected' : '');
          li.setAttribute('role', 'option');
          li.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
          li.dataset.href = `/${doc.category}/${doc.slug}/`;

          const titleEl = document.createElement('div');
          titleEl.className = 'shell-result-title';
          titleEl.textContent = doc.title;

          const tagsEl = document.createElement('div');
          tagsEl.className = 'shell-result-tags';
          tagsEl.textContent = doc.tags.join(', ');

          li.appendChild(titleEl);
          li.appendChild(tagsEl);

          li.addEventListener('click', () => {
            window.location.href = li.dataset.href;
          });

          resultsList.appendChild(li);
        });
      }

      function updateSelection(newIndex) {
        const items = resultsList.querySelectorAll('.shell-result-item');
        if (!items.length) return;
        items.forEach((el, i) => {
          el.classList.toggle('selected', i === newIndex);
          el.setAttribute('aria-selected', i === newIndex ? 'true' : 'false');
        });
        selectedIndex = newIndex;
        items[newIndex]?.scrollIntoView({ block: 'nearest' });
      }

      function openSelected() {
        const items = resultsList.querySelectorAll('.shell-result-item');
        const item = items[selectedIndex];
        if (item?.dataset.href) {
          window.location.href = item.dataset.href;
        }
      }

      input.addEventListener('input', () => {
        const query = input.value.trim();
        if (!query) {
          renderResults([]);
          return;
        }
        const results = fuse.search(query).slice(0, 8);
        renderResults(results);
      });

      // Arrow key / Enter navigation inside overlay
      input.addEventListener('keydown', (e) => {
        const items = resultsList.querySelectorAll('.shell-result-item');
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          updateSelection(Math.min(selectedIndex + 1, items.length - 1));
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          updateSelection(Math.max(selectedIndex - 1, 0));
        } else if (e.key === 'Enter') {
          e.preventDefault();
          openSelected();
        }
      });

      // Close on backdrop click (outside .shell-inner)
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) closeOverlay();
      });

      // Global keydown — open overlay with /, close with Esc
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && overlayOpen) {
          closeOverlay();
          return;
        }
        if (e.key === '/' && !overlayOpen && !isTypingContext()) {
          e.preventDefault();
          openOverlay();
        }
      });

      // Vim navigation state
      let lastGKey = 0;
      const modeLabel = document.getElementById('vim-mode-label');
      const contextLabel = document.getElementById('vim-context-label');

      function updateStatusBar(mode, context) {
        if (modeLabel) modeLabel.textContent = mode;
        if (contextLabel) contextLabel.textContent = context || '';
      }

      function selectVimItem(items, newIndex) {
        items.forEach(el => el.classList.remove('vim-selected'));
        if (newIndex < 0 || newIndex >= items.length) return;
        items[newIndex].classList.add('vim-selected');
        items[newIndex].scrollIntoView({ block: 'nearest' });
        updateStatusBar('NORMAL', `${newIndex + 1}/${items.length}`);
      }

      function getVimItems() {
        const list = document.querySelector('[data-vim-list]');
        if (!list) return [];
        return [...list.querySelectorAll('[data-vim-item]')];
      }

      function currentVimIndex(items) {
        return items.findIndex(el => el.classList.contains('vim-selected'));
      }

      function handleVimKey(e) {
        // Only act on list pages; no-op on canvas pages (graph, map)
        const items = getVimItems();
        if (!items.length) return;

        let idx = currentVimIndex(items);
        if (idx === -1) idx = 0;

        if (e.key === 'g') {
          const now = Date.now();
          if (now - lastGKey < 500) {
            // gg — go to top
            selectVimItem(items, 0);
            lastGKey = 0;
          } else {
            lastGKey = now;
          }
          return;
        }

        // Any key other than 'g' resets the gg timer
        lastGKey = 0;

        if (e.key === 'j') {
          e.preventDefault();
          selectVimItem(items, Math.min(idx + 1, items.length - 1));
        } else if (e.key === 'k') {
          e.preventDefault();
          selectVimItem(items, Math.max(idx - 1, 0));
        } else if (e.key === 'G') {
          e.preventDefault();
          selectVimItem(items, items.length - 1);
        } else if (e.key === 'Enter') {
          const selectedItem = items.find(el => el.classList.contains('vim-selected'));
          const link = selectedItem?.querySelector('a');
          if (link) {
            window.location.href = link.href;
          }
        }
      }

      // Vim keydown handler — fires when overlay is closed and not typing
      document.addEventListener('keydown', (e) => {
        if (overlayOpen) return;
        if (isTypingContext()) return;
        handleVimKey(e);
      });

      // Initialize status bar on page load for list pages
      document.addEventListener('DOMContentLoaded', () => {
        const items = getVimItems();
        if (items.length > 0) {
          updateStatusBar('NORMAL', `0/${items.length}`);
        }
      });
    </script>
  </body>
</html>
