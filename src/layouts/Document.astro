---
import Base from './Base.astro';
import TagPill from '../components/TagPill.astro';
import RelatedDocs from '../components/RelatedDocs.astro';
const { title, date, tags, relatedDocs = [] } = Astro.props;
const dateStr = date.toISOString().slice(0, 10);
---
<Base title={title}>
  <div class="doc-layout">
    <article class="doc-page">
      <header class="doc-header">
        <h1 class="doc-title">{title}</h1>
        <time class="doc-date" datetime={dateStr}>{dateStr}</time>
        <div class="doc-tags">
          {tags.map(tag => <TagPill tag={tag} />)}
        </div>
      </header>
      <div class="doc-content">
        <slot />
      </div>
    </article>
    <RelatedDocs relatedDocs={relatedDocs} />
  </div>
</Base>
