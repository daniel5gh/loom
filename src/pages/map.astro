---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import embeddingsData from '../data/embeddings.json';

// Build a lookup from doc.id (slug) → { date, summary } using Astro collections
const aiTools = await getCollection('aiTools');
const cloudPlatforms = await getCollection('cloudPlatforms');
const companies = await getCollection('companies');
const allDocs = [...aiTools, ...cloudPlatforms, ...companies];

const meta = {};
for (const doc of allDocs) {
  const body = doc.body || '';
  const summaryMatch = body.match(/## Summary\n\n([\s\S]*?)(\n##|$)/);
  meta[doc.id] = {
    date: doc.data.date ? doc.data.date.toISOString().slice(0, 10) : null,
    summary: summaryMatch ? summaryMatch[1].trim() : null,
  };
}

// Merge date and summary into each embeddings document entry
const enriched = {
  ...embeddingsData,
  documents: embeddingsData.documents.map(d => ({
    ...d,
    date: meta[d.id]?.date ?? null,
    summary: meta[d.id]?.summary ?? null,
  })),
};
const mapData = JSON.stringify(enriched);
---

<Base title="Map">
  <div class="map-page">
    <div id="map-canvas-wrap" class="map-canvas-wrap">
      <canvas id="map-canvas"></canvas>
      <div id="map-tooltip" class="map-tooltip"></div>
    </div>
  </div>

  <!-- Data island: pass build-time embeddings to client script -->
  <script type="application/json" id="map-data" set:html={mapData}></script>

  <!-- Canvas rendering: is:inline + type="module" avoids SSR execution -->
  <script is:inline type="module">
    const data = JSON.parse(document.getElementById('map-data').textContent);
    const docs = data.documents;

    // Category color map — reuse graph page neon palette
    const CATEGORY_COLORS = {
      'ai-tools-and-services': '#00E5FF',
      'cloud-ai-platforms':    '#FF2D78',
      'companies':             '#39FF14',
    };
    const FALLBACK_COLOR = '#8888AA';

    // HiDPI canvas setup — read dimensions from CSS layout, not hardcoded
    const canvas = document.getElementById('map-canvas');
    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    canvas.style.width = rect.width + 'px';
    canvas.style.height = rect.height + 'px';
    const ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);
    const W = rect.width, H = rect.height;

    // Coordinate normalization — map UMAP coords to canvas pixels
    const xs = docs.map(d => d.x), ys = docs.map(d => d.y);
    const xMin = Math.min(...xs), xMax = Math.max(...xs);
    const yMin = Math.min(...ys), yMax = Math.max(...ys);
    const PAD = 40;
    const scaleX = xMax === xMin ? () => W / 2 : v => PAD + (v - xMin) / (xMax - xMin) * (W - 2 * PAD);
    const scaleY = yMax === yMin ? () => H / 2 : v => PAD + (v - yMin) / (yMax - yMin) * (H - 2 * PAD);

    // Build dotPositions array
    const HIT_RADIUS = 8;
    const dotPositions = [];
    for (const doc of docs) {
      const cx = scaleX(doc.x), cy = scaleY(doc.y);
      dotPositions.push({ doc, cx, cy });
    }

    // Filter state — all start as "no filter active"
    let selectedTags = new Set();
    let anyAllMode = 'ANY';
    let searchQuery = '';
    let timelineDate = null;      // Date | null
    let matchingDocIds = null;    // Set<string> | null (null = no search filter)
    let selectedDot = null;       // currently clicked dot | null

    const DIM_OPACITY = 0.2;
    const SIGMA_DAYS = 5;         // tuned for current corpus date spread (~6 days)
    const NEIGHBOR_COUNT = 5;

    // Pure opacity functions (inline — map.mjs is Node-testable; is:inline cannot import bare specifiers)
    function tagOpacity(doc) {
      if (selectedTags.size === 0) return 1.0;
      const match = anyAllMode === 'ANY'
        ? doc.tags.some(t => selectedTags.has(t))
        : [...selectedTags].every(t => doc.tags.includes(t));
      return match ? 1.0 : DIM_OPACITY;
    }
    function searchOpacity(doc) {
      if (matchingDocIds === null) return 1.0;
      return matchingDocIds.has(doc.id) ? 1.0 : DIM_OPACITY;
    }
    function gaussianOp(doc) {
      if (!timelineDate || !doc.date) return 1.0;
      const docMs = new Date(doc.date).getTime();
      const selMs = timelineDate.getTime();
      const deltaDays = Math.abs(docMs - selMs) / 86400000;
      return Math.exp(-(deltaDays * deltaDays) / (2 * SIGMA_DAYS * SIGMA_DAYS));
    }
    function composedOp(doc) {
      return Math.min(tagOpacity(doc), searchOpacity(doc), gaussianOp(doc));
    }

    // kNearest inline (map.mjs is not importable in is:inline; duplicate the logic)
    function kNearest(dot, k) {
      return dotPositions
        .filter(d => d !== dot)
        .map(d => ({ d, dist: Math.sqrt((d.cx - dot.cx) ** 2 + (d.cy - dot.cy) ** 2) }))
        .sort((a, b) => a.dist - b.dist)
        .slice(0, k)
        .map(e => e.d);
    }

    function drawDot(cx, cy, color, opacity) {
      ctx.save();
      ctx.globalAlpha = opacity;
      ctx.beginPath();
      ctx.arc(cx, cy, 5, 0, 2 * Math.PI);
      ctx.fillStyle = color;
      ctx.shadowColor = color;
      ctx.shadowBlur = opacity < 0.5 ? 4 : 8; // reduce glow for dimmed dots
      ctx.fill();
      ctx.restore();
    }

    function drawNeighborLines(dot) {
      const neighbors = kNearest(dot, NEIGHBOR_COUNT);
      ctx.save();
      ctx.strokeStyle = '#8888AA';
      ctx.lineWidth = 1;
      ctx.globalAlpha = 0.4;
      for (const n of neighbors) {
        ctx.beginPath();
        ctx.moveTo(dot.cx, dot.cy);
        ctx.lineTo(n.cx, n.cy);
        ctx.stroke();
      }
      ctx.restore();
    }

    // Central redraw() — repaint canvas on every state change
    function redraw() {
      ctx.clearRect(0, 0, W, H);
      if (selectedDot) drawNeighborLines(selectedDot);
      for (const dot of dotPositions) {
        const opacity = composedOp(dot.doc);
        const color = CATEGORY_COLORS[dot.doc.category] || FALLBACK_COLOR;
        drawDot(dot.cx, dot.cy, color, opacity);
      }
    }

    // Initial draw
    redraw();

    // Tooltip hover logic (unchanged from Phase 6)
    const tooltip = document.getElementById('map-tooltip');
    canvas.addEventListener('mousemove', (event) => {
      const r = canvas.getBoundingClientRect();
      const mx = event.clientX - r.left, my = event.clientY - r.top;
      let hit = null;
      for (const dot of dotPositions) {
        const dx = dot.cx - mx, dy = dot.cy - my;
        if (Math.sqrt(dx * dx + dy * dy) < HIT_RADIUS) { hit = dot; break; }
      }
      if (hit) {
        tooltip.style.display = 'block';
        tooltip.style.left = (mx + 12) + 'px';
        tooltip.style.top = (my + 12) + 'px';
        tooltip.innerHTML = '<strong>' + hit.doc.title + '</strong><br>' + hit.doc.tags.join(', ');
      } else {
        tooltip.style.display = 'none';
      }
    });
    canvas.addEventListener('mouseleave', () => { tooltip.style.display = 'none'; });
  </script>
</Base>
