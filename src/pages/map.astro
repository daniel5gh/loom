---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import embeddingsData from '../data/embeddings.json';

// Build a lookup from doc.id (slug) → { date, summary } using Astro collections
const aiTools = await getCollection('aiTools');
const cloudPlatforms = await getCollection('cloudPlatforms');
const companies = await getCollection('companies');
const allDocs = [...aiTools, ...cloudPlatforms, ...companies];

const meta = {};
for (const doc of allDocs) {
  const body = doc.body || '';
  const summaryMatch = body.match(/## Summary\n\n([\s\S]*?)(\n##|$)/);
  meta[doc.id] = {
    date: doc.data.date ? doc.data.date.toISOString().slice(0, 10) : null,
    summary: summaryMatch ? summaryMatch[1].trim() : null,
  };
}

// Merge date and summary into each embeddings document entry
const enriched = {
  ...embeddingsData,
  documents: embeddingsData.documents.map(d => ({
    ...d,
    date: meta[d.id]?.date ?? null,
    summary: meta[d.id]?.summary ?? null,
  })),
};
const mapData = JSON.stringify(enriched);
---

<Base title="Map">
  <div class="map-page">
    <div class="map-controls">
      <input id="map-search" type="text" placeholder="search…" class="map-search-input" autocomplete="off" />
      <div id="map-tag-filter" class="map-tag-filter"></div>
      <button id="map-anyall-btn" class="map-anyall-btn any-mode">ANY</button>
      <div class="map-timeline-wrap">
        <span class="map-timeline-label">timeline</span>
        <input id="map-timeline" type="range" class="map-timeline" min="0" max="0" step="1" value="0" />
        <button id="map-play" class="map-play-btn" aria-label="Play timeline">&#x25B6;</button>
      </div>
    </div>
    <div class="map-body">
      <div id="map-canvas-wrap" class="map-canvas-wrap">
        <canvas id="map-canvas"></canvas>
        <div id="map-tooltip" class="map-tooltip"></div>
      </div>
      <div id="map-panel" class="map-panel" aria-label="Document details">
        <button id="map-panel-close" class="map-panel-close" aria-label="Close panel">×</button>
        <div id="map-panel-content" class="map-panel-content"></div>
      </div>
    </div>
  </div>

  <!-- Data island: pass build-time embeddings to client script -->
  <script type="application/json" id="map-data" set:html={mapData}></script>

  <!-- Canvas rendering: Astro-bundled module script (Fuse.js bundled locally) -->
  <script>
    import Fuse from 'fuse.js';
    const data = JSON.parse(document.getElementById('map-data').textContent);
    const docs = data.documents;

    // Category color map — reuse graph page neon palette
    const CATEGORY_COLORS = {
      'ai-tools-and-services': '#00E5FF',
      'cloud-ai-platforms':    '#FF2D78',
      'companies':             '#39FF14',
    };
    const FALLBACK_COLOR = '#8888AA';

    // Canvas state — mutable so panel open/close can resize
    const canvas = document.getElementById('map-canvas');
    const dpr = window.devicePixelRatio || 1;
    const ctx = canvas.getContext('2d');
    const HIT_RADIUS = 8;
    const PAD = 40;

    const xs = docs.map(d => d.x), ys = docs.map(d => d.y);
    const xMin = Math.min(...xs), xMax = Math.max(...xs);
    const yMin = Math.min(...ys), yMax = Math.max(...ys);

    let W, H, dotPositions = [];

    function initCanvas() {
      const wrap = canvas.parentElement;
      const rect = wrap.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      canvas.style.width = rect.width + 'px';
      canvas.style.height = rect.height + 'px';
      ctx.scale(dpr, dpr);
      W = rect.width;
      H = rect.height;
      const scaleX = xMax === xMin ? () => W / 2 : v => PAD + (v - xMin) / (xMax - xMin) * (W - 2 * PAD);
      const scaleY = yMax === yMin ? () => H / 2 : v => PAD + (v - yMin) / (yMax - yMin) * (H - 2 * PAD);
      const prevId = selectedDot ? selectedDot.doc.id : null;
      dotPositions = docs.map(doc => ({ doc, cx: scaleX(doc.x), cy: scaleY(doc.y) }));
      if (prevId) selectedDot = dotPositions.find(d => d.doc.id === prevId) || null;
    }

    initCanvas();

    // Filter state — all start as "no filter active"
    let selectedTags = new Set();
    let anyAllMode = 'ANY';
    let searchQuery = '';
    let timelineDate = null;      // Date | null
    let matchingDocIds = null;    // Set<string> | null (null = no search filter)
    let selectedDot = null;       // currently clicked dot | null

    const DIM_OPACITY = 0.2;
    const SIGMA_DAYS = 5;         // tuned for current corpus date spread (~6 days)
    const NEIGHBOR_COUNT = 5;

    // Pure opacity functions (inline — map.mjs is Node-testable; is:inline cannot import bare specifiers)
    function tagOpacity(doc) {
      if (selectedTags.size === 0) return 1.0;
      const match = anyAllMode === 'ANY'
        ? doc.tags.some(t => selectedTags.has(t))
        : [...selectedTags].every(t => doc.tags.includes(t));
      return match ? 1.0 : DIM_OPACITY;
    }
    function searchOpacity(doc) {
      if (matchingDocIds === null) return 1.0;
      return matchingDocIds.has(doc.id) ? 1.0 : DIM_OPACITY;
    }
    function gaussianOp(doc) {
      if (!timelineDate || !doc.date) return 1.0;
      const docMs = new Date(doc.date).getTime();
      const selMs = timelineDate.getTime();
      const deltaDays = Math.abs(docMs - selMs) / 86400000;
      return Math.exp(-(deltaDays * deltaDays) / (2 * SIGMA_DAYS * SIGMA_DAYS));
    }
    function composedOp(doc) {
      return Math.min(tagOpacity(doc), searchOpacity(doc), gaussianOp(doc));
    }

    // hitTest inline (map.mjs not importable from is:inline)
    function hitTestInline(mx, my) {
      for (const dot of dotPositions) {
        const dx = dot.cx - mx, dy = dot.cy - my;
        if (Math.sqrt(dx * dx + dy * dy) < HIT_RADIUS) return dot;
      }
      return null;
    }

    // kNearest inline (map.mjs is not importable in is:inline; duplicate the logic)
    function kNearest(dot, k) {
      return dotPositions
        .filter(d => d !== dot)
        .map(d => ({ d, dist: Math.sqrt((d.cx - dot.cx) ** 2 + (d.cy - dot.cy) ** 2) }))
        .sort((a, b) => a.dist - b.dist)
        .slice(0, k)
        .map(e => e.d);
    }

    function drawDot(cx, cy, color, opacity) {
      ctx.save();
      ctx.globalAlpha = opacity;
      ctx.beginPath();
      ctx.arc(cx, cy, 5, 0, 2 * Math.PI);
      ctx.fillStyle = color;
      ctx.shadowColor = color;
      ctx.shadowBlur = opacity < 0.5 ? 4 : 8; // reduce glow for dimmed dots
      ctx.fill();
      ctx.restore();
    }

    function drawNeighborLines(dot) {
      const neighbors = kNearest(dot, NEIGHBOR_COUNT);
      ctx.save();
      ctx.strokeStyle = '#8888AA';
      ctx.lineWidth = 1;
      ctx.globalAlpha = 0.4;
      for (const n of neighbors) {
        ctx.beginPath();
        ctx.moveTo(dot.cx, dot.cy);
        ctx.lineTo(n.cx, n.cy);
        ctx.stroke();
      }
      ctx.restore();
    }

    // Central redraw() — repaint canvas on every state change
    function redraw() {
      ctx.clearRect(0, 0, W, H);
      if (selectedDot) drawNeighborLines(selectedDot);
      for (const dot of dotPositions) {
        const opacity = composedOp(dot.doc);
        const color = CATEGORY_COLORS[dot.doc.category] || FALLBACK_COLOR;
        drawDot(dot.cx, dot.cy, color, opacity);
      }
    }

    // Build tag filter buttons from all unique tags in corpus
    const allTags = [...new Set(docs.flatMap(d => d.tags))].sort();
    const tagContainer = document.getElementById('map-tag-filter');
    for (const tag of allTags) {
      const btn = document.createElement('button');
      btn.className = 'tag-filter-btn';
      btn.textContent = tag;
      btn.addEventListener('click', () => {
        if (selectedTags.has(tag)) {
          selectedTags.delete(tag);
          btn.classList.remove('active');
        } else {
          selectedTags.add(tag);
          btn.classList.add('active');
        }
        redraw();
      });
      tagContainer.appendChild(btn);
    }

    // ANY/ALL toggle
    const anyAllBtn = document.getElementById('map-anyall-btn');
    anyAllBtn.addEventListener('click', () => {
      anyAllMode = anyAllMode === 'ANY' ? 'ALL' : 'ANY';
      anyAllBtn.textContent = anyAllMode;
      anyAllBtn.classList.toggle('any-mode', anyAllMode === 'ANY');
      anyAllBtn.classList.toggle('all-mode', anyAllMode === 'ALL');
      redraw();
    });

    // Initialize Fuse index once — search on input
    const fuse = new Fuse(docs, {
      keys: ['title', 'tags'],
      threshold: 0.35,
      includeScore: false,
    });

    document.getElementById('map-search').addEventListener('input', (e) => {
      const q = e.target.value.trim();
      searchQuery = q;
      if (!q) {
        matchingDocIds = null; // null = no filter active (all pass)
      } else {
        matchingDocIds = new Set(fuse.search(q).map(r => r.item.id));
      }
      redraw();
    });

    // Build sorted unique date strings from corpus and configure slider
    const uniqueDates = [...new Set(docs.filter(d => d.date).map(d => d.date))].sort();
    const slider = document.getElementById('map-timeline');
    slider.max = uniqueDates.length > 0 ? String(uniqueDates.length - 1) : '0';
    slider.value = '0';
    // timelineDate starts as null — filter only activates once user drags

    // Slider input handler
    let timelineActive = false;
    slider.addEventListener('input', () => {
      timelineActive = true;
      const idx = parseInt(slider.value, 10);
      timelineDate = uniqueDates.length > 0 ? new Date(uniqueDates[idx]) : null;
      redraw();
    });

    // Play/pause button
    let playInterval = null;
    const playBtn = document.getElementById('map-play');

    function stopPlay() {
      if (playInterval) {
        clearInterval(playInterval);
        playInterval = null;
      }
      playBtn.innerHTML = '&#x25B6;'; // ▶
      playBtn.classList.remove('playing');
    }

    function tick() {
      const max = parseInt(slider.max, 10);
      const val = parseInt(slider.value, 10);
      if (val >= max) {
        stopPlay();
        // Reset filter after play completes
        timelineDate = null;
        redraw();
        return;
      }
      slider.value = String(val + 1);
      slider.dispatchEvent(new Event('input')); // triggers input handler → redraw()
    }

    playBtn.addEventListener('click', () => {
      if (playInterval) {
        stopPlay();
      } else {
        // Reset slider to start before playing
        slider.value = '0';
        timelineDate = null;
        playInterval = setInterval(tick, 100); // 100ms per step ≈ 10fps scrub
        playBtn.innerHTML = '&#x23F8;'; // ⏸
        playBtn.classList.add('playing');
        tick(); // fire first step immediately
      }
    });

    // Cleanup on page navigation (avoids memory leak)
    window.addEventListener('pagehide', stopPlay);

    // Initial draw
    redraw();

    // Side panel open/close
    function openPanel(doc) {
      const panel = document.getElementById('map-panel');
      const content = document.getElementById('map-panel-content');
      const tagPills = doc.tags.map(t => `<span class="tag-pill">${t}</span>`).join(' ');
      content.innerHTML = `
        <h2 class="map-panel-title">${doc.title}</h2>
        <div class="map-panel-tags">${tagPills}</div>
        <p class="map-panel-summary">${doc.summary || '<em>No summary available.</em>'}</p>
        <a href="/${doc.category}/${doc.id}/" class="map-panel-link">Open article →</a>
      `;
      panel.classList.add('open');
      setTimeout(() => { initCanvas(); redraw(); }, 210);
    }
    function closePanel() {
      document.getElementById('map-panel').classList.remove('open');
      setTimeout(() => { initCanvas(); redraw(); }, 210);
    }

    // Click: select dot, draw neighbors, open panel; second click on same dot = deselect
    canvas.addEventListener('click', (event) => {
      const r = canvas.getBoundingClientRect();
      const mx = event.clientX - r.left, my = event.clientY - r.top;
      const hit = hitTestInline(mx, my);
      if (!hit) { return; }
      if (selectedDot === hit) {
        selectedDot = null;
        closePanel();
      } else {
        selectedDot = hit;
        openPanel(hit.doc);
      }
      redraw();
    });

    document.getElementById('map-panel-close').addEventListener('click', () => {
      selectedDot = null;
      closePanel();
      redraw();
    });

    // Tooltip hover logic (unchanged from Phase 6)
    const tooltip = document.getElementById('map-tooltip');
    canvas.addEventListener('mousemove', (event) => {
      const r = canvas.getBoundingClientRect();
      const mx = event.clientX - r.left, my = event.clientY - r.top;
      let hit = null;
      for (const dot of dotPositions) {
        const dx = dot.cx - mx, dy = dot.cy - my;
        if (Math.sqrt(dx * dx + dy * dy) < HIT_RADIUS) { hit = dot; break; }
      }
      if (hit) {
        tooltip.style.display = 'block';
        tooltip.style.left = (mx + 12) + 'px';
        tooltip.style.top = (my + 12) + 'px';
        tooltip.innerHTML = '<strong>' + hit.doc.title + '</strong><br>' + hit.doc.tags.join(', ');
      } else {
        tooltip.style.display = 'none';
      }
    });
    canvas.addEventListener('mouseleave', () => { tooltip.style.display = 'none'; });
  </script>
</Base>
